NODE_ENV="development"
PORT="3001"
APP_NAME="Devc NestJS REST API"
API_PREFIX="api/v1"
DATABASE_URL="postgresql://postgres:postgres@localhost:15432/devc_api?schema=public"
JWT_SECRET="replace-with-at-least-32-characters-secret"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_SECRET="replace-with-a-different-32-characters-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"
LOG_LEVEL="info"
SWAGGER_ENABLED="true"
CORS_ORIGIN="http://localhost:3000"
THROTTLE_TTL="60000"
THROTTLE_LIMIT="100"

SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-this-admin-password"
SEED_ADMIN_NAME="Devc Admin"

POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="devc_api"
